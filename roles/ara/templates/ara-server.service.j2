[Unit]
Description=ARA Records Ansible - API Server
After=network.target

[Service]
Type=simple
User={{ ara_user }}
Group={{ ara_user }}
Environment=ARA_SETTINGS={{ ara_database_dir }}/settings.yaml
ExecStart={{ ara_venv_path }}/bin/ara-manage runserver {{ ara_server_host }}:{{ ara_server_port }}
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
