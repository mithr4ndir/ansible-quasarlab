#!/usr/bin/env bash
# GPU watchdog: detects GPU failure and auto-recovers.
# Managed by Ansible, do not edit manually.
set -euo pipefail

INTERVAL=30
SMI_TIMEOUT=10
LOG_TAG="gpu-watchdog"
FAIL_COUNT=0
MAX_SOFT_RETRIES=2
EXPECTED_GPU={{ gpu_watchdog_expected_gpu_substring | quote }}
PROM_FILE="{{ node_exporter_textfile_dir }}/gpu_watchdog.prom"
TMPFILE="${PROM_FILE}.tmp"

# Passive mode: probe and emit metrics but never perform destructive recovery
# (kill ffmpeg, stop jellyfin, rmmod nvidia). Activated when the detected GPU
# does not match EXPECTED_GPU, e.g. when HA fails the VM over to a fallback
# node with a different card. Prevents 2080 Ti-tuned recovery logic from
# crash-looping on a K620 and SIGTERMing every transcode (incident 2026-05-27).
PASSIVE=0

# Load persisted counters from existing prom file
failures_total=0
soft_recoveries_total=0
hard_recoveries_total=0
if [[ -f "$PROM_FILE" ]]; then
    failures_total=$(grep -oP 'nvidia_gpu_failures_total \K[0-9]+' "$PROM_FILE" 2>/dev/null || echo 0)
    soft_recoveries_total=$(grep -oP 'nvidia_gpu_soft_recoveries_total \K[0-9]+' "$PROM_FILE" 2>/dev/null || echo 0)
    hard_recoveries_total=$(grep -oP 'nvidia_gpu_hard_recoveries_total \K[0-9]+' "$PROM_FILE" 2>/dev/null || echo 0)
fi

log() { logger -t "$LOG_TAG" "$*"; echo "$(date '+%Y-%m-%d %H:%M:%S') $*"; }

write_metrics() {
    cat > "$TMPFILE" <<METRICS
# HELP nvidia_gpu_failures_total Total number of GPU failures detected by watchdog.
# TYPE nvidia_gpu_failures_total counter
nvidia_gpu_failures_total ${failures_total}
# HELP nvidia_gpu_soft_recoveries_total Total number of successful soft recoveries (module reload).
# TYPE nvidia_gpu_soft_recoveries_total counter
nvidia_gpu_soft_recoveries_total ${soft_recoveries_total}
# HELP nvidia_gpu_hard_recoveries_total Total number of hard recoveries (VM reboot).
# TYPE nvidia_gpu_hard_recoveries_total counter
nvidia_gpu_hard_recoveries_total ${hard_recoveries_total}
METRICS
    mv "$TMPFILE" "$PROM_FILE"
    chmod 644 "$PROM_FILE"
}

# Write initial metrics
write_metrics

# Decide active vs passive mode based on the GPU currently present.
# Retry a few times because the nvidia driver can take a moment after VM boot.
for attempt in 1 2 3 4 5; do
    detected_gpu=$(timeout "$SMI_TIMEOUT" nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1 | tr -d '\r')
    if [[ -n "$detected_gpu" ]]; then
        break
    fi
    sleep 5
done

if [[ -z "$EXPECTED_GPU" ]]; then
    log "EXPECTED_GPU not configured, running in active mode regardless of detected card"
elif [[ -z "$detected_gpu" ]]; then
    log "Initial GPU probe returned no device after retries; entering PASSIVE mode (metrics only)"
    PASSIVE=1
elif [[ "$detected_gpu" != *"$EXPECTED_GPU"* ]]; then
    log "Detected GPU '$detected_gpu' does not match expected '$EXPECTED_GPU'; entering PASSIVE mode (metrics only)"
    PASSIVE=1
else
    log "Detected expected GPU: $detected_gpu"
fi

while true; do
    if timeout "$SMI_TIMEOUT" nvidia-smi --query-gpu=name --format=csv,noheader &>/dev/null; then
        FAIL_COUNT=0
        sleep "$INTERVAL"
        continue
    fi

    failures_total=$((failures_total + 1))
    FAIL_COUNT=$((FAIL_COUNT + 1))
    log "GPU failure detected (attempt ${FAIL_COUNT}/${MAX_SOFT_RETRIES}), total failures: ${failures_total}"
    write_metrics

    if [[ "$PASSIVE" -eq 1 ]]; then
        # Skip destructive recovery on fallback GPU; just probe and wait.
        sleep "$INTERVAL"
        continue
    fi

    # Stop Jellyfin to release GPU references
    log "Stopping Jellyfin..."
    systemctl stop jellyfin 2>/dev/null || true
    # Kill any lingering ffmpeg processes
    killall -9 ffmpeg 2>/dev/null || true
    sleep 5

    # Try to unload and reload NVIDIA modules
    log "Unloading NVIDIA modules..."
    rmmod nvidia_uvm 2>/dev/null || true
    rmmod nvidia_drm 2>/dev/null || true
    rmmod nvidia_modeset 2>/dev/null || true
    rmmod nvidia 2>/dev/null || true
    sleep 2

    log "Reloading NVIDIA modules..."
    if modprobe nvidia && modprobe nvidia_uvm; then
        sleep 2
        if timeout "$SMI_TIMEOUT" nvidia-smi --query-gpu=name --format=csv,noheader &>/dev/null; then
            soft_recoveries_total=$((soft_recoveries_total + 1))
            log "GPU recovered successfully (soft) — restarting Jellyfin"
            write_metrics
            systemctl start jellyfin
            FAIL_COUNT=0
            sleep "$INTERVAL"
            continue
        fi
    fi

    log "Soft recovery failed"

    if [[ "$FAIL_COUNT" -ge "$MAX_SOFT_RETRIES" ]]; then
        hard_recoveries_total=$((hard_recoveries_total + 1))
        log "Exhausted ${MAX_SOFT_RETRIES} soft recovery attempts — waiting for host PCI reset"
        write_metrics
        # Don't reboot — the Proxmox host monitor will detect the failure,
        # stop the VM, reset the GPU PCI device, and restart the VM.
        # Keep checking in case the host recovers us.
        sleep 60
        FAIL_COUNT=0
        continue
    fi

    # Retry after a longer wait before giving up
    sleep 10
done
