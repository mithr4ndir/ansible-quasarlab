#!/usr/bin/env bash
# PostgreSQL backup script — managed by Ansible
set -euo pipefail

BACKUP_DIR="{{ postgresql_backup_mount_point }}"
RETENTION_DAYS={{ postgresql_backup_retention_days }}
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
HOSTNAME=$(hostname -s)

# Verify NFS mount is available
if ! mountpoint -q "${BACKUP_DIR}"; then
    echo "ERROR: Backup directory ${BACKUP_DIR} is not mounted" >&2
    exit 1
fi

# Create host-specific subdirectory
HOST_DIR="${BACKUP_DIR}/${HOSTNAME}"
mkdir -p "${HOST_DIR}"

# Dump all databases individually
{% for db in postgresql_databases %}
echo "Backing up database: {{ db.name }}"
pg_dump -Fc --file="${HOST_DIR}/{{ db.name }}_${TIMESTAMP}.dump" {{ db.name }}
{% endfor %}

# Dump global objects (roles, tablespaces)
echo "Backing up global objects"
pg_dumpall --globals-only --file="${HOST_DIR}/globals_${TIMESTAMP}.sql"

# Prune backups older than retention period
echo "Pruning backups older than ${RETENTION_DAYS} days"
find "${HOST_DIR}" -type f \( -name '*.dump' -o -name '*.sql' \) -mtime +${RETENTION_DAYS} -delete

echo "Backup completed at $(date)"
