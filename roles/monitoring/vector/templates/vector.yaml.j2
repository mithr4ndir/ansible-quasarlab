data_dir: /var/lib/vector

sources:
  journald:
    type: journald

  var_log:
    type: file
    include:
      - /var/log/nginx/*.log
      - /var/log/haproxy.log
      - /var/log/jellyfin/*.log
      - /var/log/pve*.log
      - /var/log/gpu-*.log
      - /var/log/failover.log
      - /var/log/dpkg.log
      - /var/log/cloud-init*.log
      - /var/log/ansible-quasarlab/*.log
    read_from: end
    ignore_older_secs: 86400

{% if 'security' in group_names %}
  wazuh_alerts:
    type: file
    include:
      - /var/ossec/logs/alerts/alerts.json
    read_from: end
    ignore_older_secs: 86400
{% endif %}

transforms:
  noise_filter:
    type: filter
    inputs:
      - journald
      - var_log
    condition: '!contains(string!(.message), "NVRM: No NVIDIA GPU found")'

  remap:
    type: remap
    inputs:
      - noise_filter
    source: |
      .job = "varlogs"
      .host = "{{ inventory_hostname }}"
      if exists(.file) {
        file_path = string!(.file)
        if contains(file_path, "kern") {
          .log_type = "kernel"
        } else {
          .log_type = "application"
        }
        parts = split!(file_path, "/")
        if length(parts) > 3 {
          .app = parts[3]
        } else {
          .app = "system"
        }
        del(.file)
      } else {
        .log_type = "journal"
        .app = string(._SYSTEMD_UNIT) ?? string(.SYSLOG_IDENTIFIER) ?? "system"
      }
      del(.source_type)

{% if 'security' in group_names %}
  wazuh_remap:
    type: remap
    inputs:
      - wazuh_alerts
    source: |
      .job = "wazuh"
      .host = "{{ inventory_hostname }}"
      .log_type = "security"
      .app = "wazuh"
      if exists(.rule) {
        rule = object!(.rule)
        .wazuh_rule_id = string(rule.id) ?? ""
        .wazuh_rule_level = to_string(rule.level) ?? ""
        .wazuh_rule_description = string(rule.description) ?? ""
      }
      if exists(.agent) {
        agent = object!(.agent)
        .wazuh_agent = string(agent.name) ?? ""
      }
      del(.source_type)
      del(.file)
{% endif %}

sinks:
  loki:
    type: loki
    inputs:
      - remap
{% if 'security' in group_names %}
      - wazuh_remap
{% endif %}
    endpoint: "{{ loki_endpoint }}"
    encoding:
      codec: json
    labels:
      job: "{% raw %}{{ job }}{% endraw %}"
      host: "{% raw %}{{ host }}{% endraw %}"
      log_type: "{% raw %}{{ log_type }}{% endraw %}"
      app: "{% raw %}{{ app }}{% endraw %}"
    remove_label_fields: true
    out_of_order_action: accept
