data_dir: /var/lib/vector

sources:
  journald:
    type: journald

  var_log:
    type: file
    include:
      - /var/log/**/*.log
      - /var/log/*.log
    exclude:
      - /var/log/filebeat/**
      - /var/log/journal/**
      - /var/log/vector/**
      - /var/log/syslog
      - /var/log/auth.log
      - /var/log/kern.log
      - /var/log/apt/**
      - /var/log/unattended-upgrades/**
    read_from: end
    ignore_older_secs: 86400

transforms:
  noise_filter:
    type: filter
    inputs:
      - journald
      - var_log
    condition: '!contains(string!(.message), "NVRM: No NVIDIA GPU found")'

  remap:
    type: remap
    inputs:
      - noise_filter
    source: |
      .job = "varlogs"
      .host = "{{ inventory_hostname }}"
      if exists(.file) {
        file_path = string!(.file)
        if contains(file_path, "kern") {
          .log_type = "kernel"
        } else {
          .log_type = "application"
        }
        parts = split!(file_path, "/")
        if length(parts) > 3 {
          .app = parts[3]
        } else {
          .app = "system"
        }
        del(.file)
      } else {
        .log_type = "journal"
        .app = string(._SYSTEMD_UNIT) ?? string(.SYSLOG_IDENTIFIER) ?? "system"
      }
      del(.source_type)

sinks:
  loki:
    type: loki
    inputs:
      - remap
    endpoint: "{{ loki_endpoint }}"
    encoding:
      codec: json
    labels:
      job: "{% raw %}{{ job }}{% endraw %}"
      host: "{% raw %}{{ host }}{% endraw %}"
      log_type: "{% raw %}{{ log_type }}{% endraw %}"
      app: "{% raw %}{{ app }}{% endraw %}"
    remove_label_fields: true
    out_of_order_action: accept
