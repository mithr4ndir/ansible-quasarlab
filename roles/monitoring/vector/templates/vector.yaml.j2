data_dir: /var/lib/vector

sources:
  journald:
    type: journald

  var_log:
    type: file
    include:
      - /var/log/*.log
    exclude:
      - /var/log/filebeat/*.log
      - /var/log/syslog
      - /var/log/auth.log
      - /var/log/kern.log
    read_from: end

transforms:
  noise_filter:
    type: filter
    inputs:
      - journald
      - var_log
    condition: '!contains(to_string(.message) ?? "", "NVRM: No NVIDIA GPU found")'

  remap:
    type: remap
    inputs:
      - noise_filter
    source: |
      .job = "varlogs"
      .host = "{{ inventory_hostname }}"
      if exists(.file) {
        file_path = to_string!(.file)
        if contains(file_path, "kern") {
          .log_type = "kernel"
        } else {
          .log_type = "application"
        }
        del(.file)
      } else {
        .log_type = "journal"
      }
      del(.source_type)

sinks:
  loki:
    type: loki
    inputs:
      - remap
    endpoint: "{{ loki_endpoint }}"
    encoding:
      codec: json
    labels:
      job: "{% raw %}{{ job }}{% endraw %}"
      host: "{% raw %}{{ host }}{% endraw %}"
      log_type: "{% raw %}{{ log_type }}{% endraw %}"
    remove_label_fields: true
    out_of_order_action: accept
